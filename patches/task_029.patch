+theorem tail_toList_eq_toList_tail {α} {n : ℕ} (v : Vector α n) : v.tail.toList = v.toList.tail := by
+  rw [Vector.tail_eq_cast_extract, Vector.toList_cast, Vector.toList_extract]
+  rw [List.drop_one]
+  apply List.take_of_length_le
+  rw [List.length_tail, Vector.length_toList]
