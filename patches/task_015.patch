+theorem sum_inv_pow_Icc_eq_range {curBTField : Type*} [Field curBTField] (u : curBTField) (k : ℕ)
+  (x_pow_card : ∀ (x : curBTField), x ^ (2 ^ (2 ^ k)) = x) :
+  ∑ j ∈ Finset.Icc 1 (2 ^ k), (u⁻¹) ^ (2 ^ j) = ∑ j ∈ Finset.range (2 ^ k), (u⁻¹) ^ (2 ^ j) := by
+  let f : ℕ → curBTField := fun j => (u⁻¹) ^ (2 ^ j)
+  have hIcc : ∑ j ∈ Finset.Icc 1 (2 ^ k), f j = ∑ j ∈ Finset.Ico 1 (2 ^ k + 1), f j := by
+    rw [← Finset.Ico_add_one_right_eq_Icc]
+  rw [hIcc]
+  rw [Finset.sum_Ico_eq_sum_range]
+  simp only [Nat.add_comm 1, Nat.add_left_comm, Nat.add_assoc, Nat.add_sub_cancel]
+  have hsucc : ∑ x ∈ Finset.range (2 ^ k + 1), f x = ∑ x ∈ Finset.range (2 ^ k), f x + f (2 ^ k) := by
+    exact Finset.sum_range_succ f (2 ^ k)
+  have hsucc' : ∑ x ∈ Finset.range (2 ^ k + 1), f x = ∑ x ∈ Finset.range (2 ^ k), f (x + 1) + f 0 := by
+    exact Finset.sum_range_succ' f (2 ^ k)
+  have hend : f (2 ^ k) = f 0 := by
+    dsimp [f]
+    simpa using x_pow_card (u⁻¹)
+  have hsum : ∑ x ∈ Finset.range (2 ^ k), f x + f 0 = ∑ x ∈ Finset.range (2 ^ k), f (x + 1) + f 0 := by
+    calc
+      ∑ x ∈ Finset.range (2 ^ k), f x + f 0 = ∑ x ∈ Finset.range (2 ^ k), f x + f (2 ^ k) := by rw [hend]
+      _ = ∑ x ∈ Finset.range (2 ^ k + 1), f x := hsucc.symm
+      _ = ∑ x ∈ Finset.range (2 ^ k), f (x + 1) + f 0 := hsucc'
+  exact (add_right_cancel hsum).symm
+
