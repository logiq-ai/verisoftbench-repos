+theorem acyclic_has_leaf_aux_candidate_is_leaf (R : Run S) (root current y : S)
+    (path : List S)
+    (h_acyclic : R.isAcyclic)
+    (h_start : path.head? = some root)
+    (h_end : path.getLast? = some current)
+    (h_nonempty : path ≠ [])
+    (h_contains : R.containsPath path)
+    (h_y_not_in_path : y ∉ path)
+    (h_edge : R (current, y) > 0)
+    (h_no_fresh_out : ¬ ∃ z, z ∉ path ∧ z ≠ y ∧ R (y, z) > 0) :
+    R.isLeaf root y := by
+  constructor
+  · refine ⟨path ++ [y], ?_, ?_, ?_, ?_⟩
+    · obtain ⟨x, xs, rfl⟩ := List.exists_cons_of_ne_nil h_nonempty
+      simpa [List.cons_append] using h_start
+    · simpa using (List.getLast?_concat (l := path) (a := y))
+    · simp
+    · exact containsPath_append_singleton R path current y h_nonempty h_end h_contains h_y_not_in_path h_edge
+  · intro z
+    by_contra hz0
+    have hzpos : R (y, z) > 0 := Nat.pos_of_ne_zero hz0
+    by_cases hz_in_path : z ∈ path
+    · have h_ext_contains : R.containsPath (path ++ [y]) :=
+        containsPath_append_singleton R path current y h_nonempty h_end h_contains h_y_not_in_path h_edge
+      have h_end_ext : (path ++ [y]).getLast? = some y := by
+        simpa using (List.getLast?_concat (l := path) (a := y))
+      have h_z_in_ext : z ∈ path ++ [y] := by
+        exact List.mem_append.mpr (Or.inl hz_in_path)
+      exact acyclic_edge_not_in_path R (path ++ [y]) y z h_acyclic h_end_ext h_ext_contains hzpos h_z_in_ext
+    · by_cases hzy : z = y
+      · subst z
+        exact acyclic_no_self_loop R y h_acyclic hzpos
+      · exact h_no_fresh_out ⟨z, hz_in_path, hzy, hzpos⟩
+
+theorem acyclic_has_leaf_aux_measure_decrease (path : List S) (y : S) (h_y_not_in_path : y ∉ path) :
+    Fintype.card S - (path ++ [y]).toFinset.card < Fintype.card S - path.toFinset.card := by
+  have h_y_not_mem : y ∉ path.toFinset := by
+    simpa using h_y_not_in_path
+  have h_toFinset : (path ++ [y]).toFinset = insert y path.toFinset := by
+    simp [List.toFinset_append, h_y_not_mem]
+  have h_card_lt : path.toFinset.card < Fintype.card S := by
+    simpa [Finset.card_univ] using Finset.card_lt_univ_of_notMem h_y_not_mem
+  rw [h_toFinset, Finset.card_insert_of_notMem h_y_not_mem]
+  omega
