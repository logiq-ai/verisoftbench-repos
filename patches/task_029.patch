+theorem toList_eq_head_cons_tail_of_neZero {α} {n : ℕ} [NeZero n] (v : Vector α n) : v.toList = v.head :: v.toList.tail := by
+  have hpos : 0 < v.toList.length := by
+    simpa using (Nat.pos_of_neZero n)
+  cases h : v.toList with
+  | nil =>
+      simp [h] at hpos
+  | cons hd tl =>
+      have hhd : hd = v.head := by
+        simpa [Vector.head, h] using (v.getElem_toList (i := 0) (h := by simpa [h] using hpos))
+      simp [h, hhd]
+
+theorem foldl_succ {α β} {n : ℕ} [NeZero n] (f : β → α → β) (init : β) (v : Vector α n) : v.foldl (f:=f) (b:=init) = v.tail.foldl (f:=f) (b:=f init v.head) := by
